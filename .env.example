# Copy to .env.local and fill in real values. Never commit .env.local.

# ── Supabase (frontend, exposed) ─────────────────────────────────────
# From: Supabase project → Settings → API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=ey...

# ── Cloudflare R2 (server-only — read by /api/r2-sign) ───────────────
# From: Cloudflare dashboard → R2 → Manage R2 API Tokens (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ugc-lab-assets
# Optional: a public custom domain bound to the bucket. If unset, signed
# URLs go directly to the R2 endpoint (also works).
R2_PUBLIC_BASE_URL=

# Same Supabase URL again, but used by the Vercel API route to verify JWTs.
# Keep this server-side; it's the same value as VITE_SUPABASE_URL.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=ey...
